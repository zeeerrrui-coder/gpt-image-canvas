# OpenAI image API configuration.
# Do not commit real API keys.
# Leave OPENAI_BASE_URL empty to use the official OpenAI API.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_MS=1200000

# Server/runtime.
PORT=8787
HOST=127.0.0.1
DATA_DIR=./data

# SQLite storage.
# Leave blank to use WAL locally; Docker Compose defaults to DELETE + EXCLUSIVE for bind-mounted data.
SQLITE_JOURNAL_MODE=
SQLITE_LOCKING_MODE=

# Optional cloud asset storage.
# The app stores generated images locally by default. Configure this from the in-app
# cloud storage settings dialog when you want generated images to be uploaded to COS.
# These defaults only prefill the COS settings dialog; SecretId and SecretKey are
# entered in the UI and stored locally in SQLite after a successful test upload.
# Secrets saved from the UI are stored in the local SQLite database and are never
# returned in full by the settings API.
COS_DEFAULT_BUCKET=source-1253253332
COS_DEFAULT_REGION=ap-nanjing
COS_DEFAULT_KEY_PREFIX=gpt-image-canvas/assets
